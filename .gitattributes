# SIMPROK Git attributes
# Keep source files normalized in repository to avoid CRLF/LF false dirty noise.

* text=auto

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary / archives
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.pdf binary
*.zip binary
*.xlsx binary
*.xls binary
*.docx binary
